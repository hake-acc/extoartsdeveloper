# Block execution of any script in the uploads directory.
# Files here are served as static assets only.
Options -ExecCGI
php_flag engine off
RemoveHandler .php .php3 .php4 .php5 .php7 .php8 .phtml .phar
AddType text/plain .php .php3 .php4 .php5 .php7 .php8 .phtml .phar

<FilesMatch "\.(php|php3|php4|php5|php7|php8|phtml|phar|pl|py|cgi|sh|asp|aspx|jsp)$">
    Require all denied
</FilesMatch>
