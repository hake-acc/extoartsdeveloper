# ============================================================
# ExtoArts - Next.js Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to Git.
# ============================================================

# Supabase (get from your Supabase dashboard -> Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# Cloudflare Turnstile CAPTCHA (get from dash.cloudflare.com -> Turnstile)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key
TURNSTILE_SECRET_KEY=your-turnstile-secret-key

# Discord webhook for registration notifications
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
DISCORD_WEBHOOK_APPS=https://discord.com/api/webhooks/...

# Health check token (any random string)
HEALTH_CHECK_TOKEN=change-this-to-a-random-string

# Production domain (used for canonical URLs)
NEXT_PUBLIC_SITE_URL=https://extoarts.in
