# ExtoArts — Next.js Environment Variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.

# ── Supabase ──────────────────────────────────────────────────────────────────
# Get these from: https://app.supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Server-only service role key (never expose to the browser)
SUPABASE_SERVICE_KEY=your-service-role-key-here

# ── Discord Webhooks ───────────────────────────────────────────────────────────
# Ticket submissions (required for /ticket form to work)
DISCORD_WEBHOOK_TICKET=https://discord.com/api/webhooks/...

# New editor applications (required for /apply form notifications)
DISCORD_WEBHOOK_APPLICATIONS=https://discord.com/api/webhooks/...

# New user registrations (optional)
DISCORD_WEBHOOK_REGISTRATIONS=https://discord.com/api/webhooks/...
